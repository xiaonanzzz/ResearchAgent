# Makefile for exp-<idea-name>
#
# Three required targets:
#   build    - Install dependencies, prepare data
#   run      - Execute the experiment (must be deterministic)
#   evaluate - Run evaluation using a shared evaluation protocol
#
# Usage:
#   make build       # first time setup
#   make run         # run the experiment
#   make evaluate    # evaluate outputs

# ─── Configuration ───────────────────────────────────────────────────────────

SEED       := 42
OUTPUT_DIR := output
CONFIG     := config.yaml

# ─── Targets ─────────────────────────────────────────────────────────────────

.PHONY: build run evaluate clean

build:
	# Install dependencies (choose one approach):
	# pip install -r requirements.txt
	# uv sync

run:
	mkdir -p $(OUTPUT_DIR)
	python train.py --config $(CONFIG) --seed $(SEED) --output-dir $(OUTPUT_DIR) 2>&1 | tee $(OUTPUT_DIR)/run.log

evaluate:
	# run_eval.py imports data & eval protocols via sys.path and calls evaluate(dataset, predictions)
	python run_eval.py --output $(OUTPUT_DIR)/eval_results.json

clean:
	rm -rf $(OUTPUT_DIR)
